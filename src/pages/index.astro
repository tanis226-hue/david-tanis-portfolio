---
import Layout from '../layouts/Layout.astro';

// The lead. iepOS keeps long-form prose because the feature well is where
// long-form belongs. Everything below is counted from the source.
const lead = {
	name: 'iepOS',
	kind: 'Flagship product',
	claim:
		'A universal student learning OS for schools and districts. One data model, one workflow, three configurations.',
	prose: [
		'Formal IDEA IEP and 504 compliance workflows sit inside it as a tier rather than the centerpiece, so a district buys one system instead of three.',
		'Turborepo monorepo: a Next.js 16 web app, a mobile client, and eight shared packages on Prisma, Postgres, and NextAuth v5, with Anthropic models isolated behind a dedicated AI package. Architecture is enforced in CI, not by convention. Dedicated checks gate the engine boundary, the read-model boundary, multi-tenancy, migration rollback sections, and prompt-evaluation bumps.',
	],
	stack: ['Next.js 16', 'Turborepo', 'Prisma on Postgres', 'Anthropic'],
	stats: [
		{ value: '8', label: 'shared packages' },
		{ value: '5', label: 'boundaries gated in CI' },
		{ value: '2', label: 'clients, web and mobile' },
		{ value: '3', label: 'configurations, one data model' },
	],
	source: 'Private repo, walkthrough on request',
};

// The index. Five ruled rows. Proof sentences are kept in full: the clause
// naming the eight unguarded routes is the proof the code was actually read.
const work = [
	{
		name: 'ZLDA Health',
		kind: 'Multi-tenant operations platform',
		claim:
			'Back-office platform for physician groups and post-acute facilities. Sits beside the EHR rather than replacing one.',
		proof:
			'Audit-log immutability enforced in Postgres with DELETE rules and UPDATE triggers, and AES-256-GCM envelope encryption with per-value IVs, versioned for key rotation. Of 220 API routes, 212 carry an auth guard; the eight exceptions are health probes, auth endpoints, and a constant-time bearer-compared backup route.',
		stack: ['Next.js', 'Postgres RLS', 'Azure', 'HIPAA safeguards'],
		stats: [
			{ value: '96,600', label: 'lines of TypeScript' },
			{ value: '93', label: 'Prisma models' },
			{ value: '212/220', label: 'API routes guarded' },
			{ value: '51', label: 'migrations' },
		],
		source: { label: 'Private repo, walkthrough on request' },
	},
	{
		name: 'RavePM',
		kind: 'AI governance architecture',
		claim:
			'AI-native property management. The interesting part is not the AI, it is the layer that decides what the AI may do.',
		proof:
			'A hardcoded set of actions the model can never auto-execute, org-configurable approval rules with dollar-band fallbacks, and an audit row for every outcome recording what was done, why, which data was used, and who approved.',
		stack: ['Turborepo', 'Drizzle', 'Stripe', 'Approval gates'],
		stats: [
			{ value: '49,700', label: 'lines' },
			{ value: '53', label: 'tables' },
			{ value: '57', label: 'test files' },
			{ value: '3', label: 'tiers in the model router' },
		],
		source: { label: 'Private repo, walkthrough on request' },
	},
	{
		name: 'ZLDA Assistant',
		kind: 'Production LLM engineering',
		claim:
			'A private executive assistant with real write access to tasks, calendar, email, CRM, and finance.',
		proof:
			'Bounded agentic loop with a hard step ceiling, parallel tool fan-out, and loop detection by hashed tool signature, over a full pgvector RAG pipeline with per-model USD cost accounting. It ships its own MCP server exposing every tool to external clients.',
		stack: ['Agent loop', 'pgvector RAG', 'MCP server', 'Prompt caching'],
		stats: [
			{ value: '45+', label: 'write-capable tools' },
			{ value: '87', label: 'API routes' },
			{ value: '34', label: 'data models' },
			{ value: '40', label: 'step loop ceiling' },
		],
		source: { label: 'Private repo, walkthrough on request' },
	},
	{
		name: 'NBA Trade Machine',
		kind: 'Deterministic rules engine',
		claim:
			'The 2023 NBA Collective Bargaining Agreement implemented as a correctness engine. Zero AI anywhere, on purpose.',
		proof:
			'A 13-rule ordered pipeline emitting 29 finding codes, each carrying a real CBA citation and an actionable fix, plus an auto-fix solver that returns the mutations making an illegal trade legal. Next-season dollar thresholds are marked as estimates in the code.',
		stack: ['TypeScript', 'Rules engine', 'Adversarial tests'],
		stats: [
			{ value: '13', label: 'rules in the pipeline' },
			{ value: '29', label: 'finding codes' },
			{ value: '195', label: 'tests across 29 files' },
			{ value: '0', label: 'models called' },
		],
		source: { label: 'Public on GitHub', href: 'https://github.com/tanis226-hue/nba-trade-machine' },
	},
	{
		name: 'Client systems',
		kind: 'Delivered engagements',
		claim:
			'Commerce, scheduling, and intake for a restoration shop, a bakery, and a landscaping business.',
		proof:
			'Prices recomputed server-side so amounts never originate from the browser, idempotent Stripe webhooks guarded by status preconditions, and authorization pushed into Postgres row-level security rather than route handlers.',
		stack: ['Stripe', 'Neon', 'Netlify Functions', 'Postgres RLS'],
		stats: [
			{ value: '3', label: 'businesses served' },
			{ value: '2', label: 'front doors, one database' },
			{ value: '0', label: 'prices trusted from the browser' },
		],
		source: { label: 'Client repos, private' },
	},
];

const heroLedger = [
	{ value: '6', label: 'production systems built and shipped' },
	{ value: '212', label: "of ZLDA Health's 220 API routes carry an auth guard" },
	{ value: '146,300', label: 'lines across the two largest codebases' },
	{ value: '0', label: 'usage or revenue figures on this page', accent: true },
];

const principles = [
	{
		title: 'Deterministic core, model at the edges',
		body: 'Where correctness matters the arithmetic is hand-written and tested, and the model only interprets or drafts. Metrics get computed in code before anything reaches a prompt.',
	},
	{
		title: 'The client is never trusted',
		body: 'Prices, dates, and authorization are re-derived server-side in every system I build. Checkout rebuilds the cart from the database. The browser gets a vote, not a verdict.',
	},
	{
		title: 'Governance in the database',
		body: 'Audit immutability and tenant isolation belong in DELETE rules, triggers, and row-level security. A missed check in a route handler should not be able to bypass them.',
	},
	{
		title: 'Degrade gracefully by default',
		body: 'Missing provider credentials skip their channel instead of erroring. Fallback catalogs render when the database returns nothing. Stale config serves while the database is unreachable.',
	},
];

const nav = [
	{ href: '#work', label: 'Work' },
	{ href: '#method', label: 'Method' },
	{ href: '#writing', label: 'Writing' },
	{ href: '#contact', label: 'Contact' },
];

// Published essays on ZLDA Insights, newest first.
const base = 'https://www.zldagroup.com/insights';
const essays = [
	{ date: '2026-07-14', title: 'Cost Discipline for AI: How to Think About ROI', href: `${base}/cost-discipline-for-ai` },
	{ date: '2026-07-01', title: 'Build, Buy, or Rent: The Software Math Just Changed', href: `${base}/build-buy-or-rent` },
	{ date: '2026-06-24', title: 'How to Safely Get Started with AI Coding', href: `${base}/how-to-safely-get-started-with-ai-coding` },
	{ date: '2026-06-15', title: "Most Companies Aren't Ready for AI", href: `${base}/most-companies-arent-ready-for-ai` },
	{ date: '2026-05-31', title: 'The Need to Know: AI Vibe Coding', href: `${base}/the-need-to-know-ai-vibe-coding` },
	{ date: '2026-05-24', title: 'Why Growing Businesses Start to Feel Inefficient', href: `${base}/why-growing-businesses-start-to-feel-inefficient` },
];

const title = 'David Tanis - Operator and systems builder';
const description =
	'I build the systems businesses run on: governance-grade data models, AI with approval gates, and operations software that survives contact with real users.';
---

<Layout title={title} description={description}>
	<header
		class="masthead sticky top-0 z-40 backdrop-blur-md"
		style="background-color: rgb(var(--color-bg-rgb) / 0.85)"
	>
		<div class="wrap-wide flex items-center justify-between py-3.5">
			<a href="#main" class="font-display text-lg font-bold tracking-tight">David Tanis</a>
			<nav aria-label="Sections" class="flex items-center gap-4 sm:gap-6">
				<ul class="hidden items-center gap-6 font-mono text-[0.75rem] lowercase tracking-wide text-ink-soft sm:flex">
					{
						nav.map((n) => (
							<li>
								<a href={n.href} class="transition hover:text-accent-dark">
									{n.label}
								</a>
							</li>
						))
					}
				</ul>
				<button
					id="theme-toggle"
					type="button"
					aria-label="Toggle dark mode"
					class="rounded-md px-3 py-1.5 text-meta font-semibold text-ink-muted transition hover:text-ink"
					style="border: 1px solid rgb(var(--color-border-rgb) / 0.14)"
				>
					Theme
				</button>
			</nav>
		</div>
	</header>

	<main id="main">
		<!-- Opening spread -->
		<section class="wrap grid gap-10 pb-12 pt-10 sm:pt-14 lg:grid-cols-[1.55fr_1fr] lg:items-center lg:gap-14">
			<div>
				<p class="kicker">Naples, Florida</p>
				<h1 class="mt-5 text-display">
					I build the systems <span class="text-accent-dark">businesses actually run on.</span>
				</h1>
				<p class="mt-6 max-w-[42ch] text-body-l text-ink-soft">
					Operations and data by background, engineer by practice. I take messy, fast-moving
					environments and give them a spine: clear workflows, an honest data model, and software
					the team will still be using in a year.
				</p>
				<div class="mt-8 flex flex-wrap items-center gap-3">
					<a href="mailto:tanis226@gmail.com" class="btn-primary">Get in touch</a>
					<a href="#lead" class="btn-ghost">See the work</a>
					<a href="/David-Tanis-Resume.pdf" class="px-2 text-sm font-bold text-ink transition hover:text-accent-dark">Résumé</a>
					<a href="/David-Tanis-CV.pdf" class="px-2 text-sm font-bold text-ink transition hover:text-accent-dark">CV</a>
					<a href="https://github.com/tanis226-hue" class="px-2 text-sm font-bold text-ink transition hover:text-accent-dark">GitHub</a>
				</div>
			</div>
			<div class="lg:justify-self-end">
				<div class="max-w-[15rem]">
					<img
						src="/david-tanis-480.webp"
						srcset="/david-tanis-480.webp 480w, /david-tanis-960.webp 960w"
						sizes="200px"
						width="200"
						height="200"
						alt="David Tanis"
						fetchpriority="high"
						class="avatar h-[140px] w-[140px] sm:h-[188px] sm:w-[188px]"
					/>
					<p class="mt-5 text-body text-ink-soft">
						I co-founded <a class="link-accent" href="https://zldagroup.com">ZLDA Group</a>, where
						most of this ships. MBA, PMP, and an MS in progress at FGCU.
					</p>
				</div>
			</div>
		</section>

		<!-- Hero ledger: the whole argument in four figures -->
		<section class="wrap pb-14 sm:pb-16">
			<dl class="grid grid-cols-2 gap-x-6 gap-y-8 border-t border-line/12 pt-8 md:grid-cols-4">
				{
					heroLedger.map((s) => (
						<div class="flex flex-col-reverse gap-2">
							<dt class="stat-label">{s.label}</dt>
							<dd class={`stat${s.accent ? ' stat-accent' : ''}`}>{s.value}</dd>
						</div>
					))
				}
			</dl>
			<p class="mt-8 max-w-[64ch] text-body text-ink-soft">
				Every figure on this page is engineering scale, counted from a direct read of the source
				rather than a README. There are no usage, revenue, or customer numbers anywhere, because none
				are supported. I would rather show you what I built than imply traction I do not have.
			</p>
		</section>

		<!-- The lead: iepOS, full-bleed band -->
		<section id="lead" class="bg-bg-soft scroll-mt-20">
			<div class="wrap-wide grid gap-10 py-14 sm:py-16 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] lg:items-center lg:gap-16">
				<div>
					<p class="kicker text-accent-dark">The lead / {lead.kind}</p>
					<h2 class="mt-4 text-lead">{lead.name}</h2>
					<p class="mt-4 text-body-l text-ink-soft">{lead.claim}</p>
					<ul class="tech mt-6 flex flex-wrap items-center gap-x-2.5 gap-y-1">
						{
							lead.stack.map((s, i) => (
								<>
									{i > 0 && <li aria-hidden="true" class="text-accent-dark">/</li>}
									<li>{s}</li>
								</>
							))
						}
					</ul>
					<p class="provenance mt-6">// {lead.source}</p>
				</div>
				<div>
					<p class="text-body-l text-ink">{lead.prose[0]}</p>
					<p class="mt-5 text-body text-ink-soft">{lead.prose[1]}</p>
					<dl class="mt-9 grid grid-cols-2 gap-x-8 gap-y-6 border-t border-line/12 pt-7 sm:grid-cols-4">
						{
							lead.stats.map((s) => (
								<div class="flex flex-col-reverse gap-1.5">
									<dt class="stat-label">{s.label}</dt>
									<dd class="stat-sm">{s.value}</dd>
								</div>
							))
						}
					</dl>
				</div>
			</div>
		</section>

		<!-- The index: five ruled rows -->
		<section id="work" class="wrap-wide scroll-mt-20 py-14 sm:py-16">
			<div class="flex flex-wrap items-baseline justify-between gap-4 border-b border-line/15 pb-5">
				<h2 class="text-lead">Five more systems.</h2>
				<p class="kicker">Counted from the code, not estimated</p>
			</div>
			<ol>
				{
					work.map((item, i) => (
						<li class="index-row grid gap-5 border-b border-line/10 py-8 lg:grid-cols-[minmax(0,13rem)_minmax(0,1fr)_minmax(0,17rem)] lg:gap-10">
							<div>
								<p class="kicker text-ink-muted">
									{String(i + 2).padStart(2, '0')} / {item.kind}
								</p>
								<h3 class="mt-2 text-title">{item.name}</h3>
								<ul class="tech mt-2.5 flex flex-wrap gap-x-3 gap-y-1">
									{item.stack.map((s) => (
										<li>{s}</li>
									))}
								</ul>
								<p class="provenance mt-4">
									{item.source.href ? (
										<a class="link-accent" href={item.source.href} target="_blank" rel="noopener">
											{item.source.label} &#8599;
										</a>
									) : (
										<span>// {item.source.label}</span>
									)}
								</p>
							</div>
							<div>
								<p class="text-body text-ink">{item.claim}</p>
								<p class="mt-2.5 text-meta text-ink-soft">{item.proof}</p>
							</div>
							<dl class="grid grid-cols-2 gap-x-6 gap-y-4 self-start lg:border-l lg:border-line/12 lg:pl-8">
								{item.stats.map((s) => (
									<div class="flex flex-col-reverse gap-1">
										<dt class="stat-label">{s.label}</dt>
										<dd class="stat-sm">{s.value}</dd>
									</div>
								))}
							</dl>
						</li>
					))
				}
			</ol>
		</section>

		<!-- Method -->
		<section id="method" class="bg-bg-soft scroll-mt-20">
			<div class="wrap py-14 sm:py-16">
				<p class="kicker">How I build</p>
				<h2 class="mt-4 max-w-[24ch] text-lead">Opinions that survived contact with production.</h2>
				<div class="mt-10 grid gap-x-10 gap-y-8 sm:grid-cols-2">
					{
						principles.map((p, i) => (
							<div class="border-t border-line/12 pt-5">
								<p class="kicker text-ink-muted">{String(i + 1).padStart(2, '0')}</p>
								<h3 class="mt-2 text-body-l font-semibold text-accent-dark">{p.title}</h3>
								<p class="mt-2 text-meta text-ink-soft">{p.body}</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- Writing: essay index -->
		<section id="writing" class="wrap-wide scroll-mt-20 py-14 sm:py-16">
			<div class="flex flex-wrap items-baseline justify-between gap-4 border-b border-line/15 pb-5">
				<div>
					<p class="kicker">Writing</p>
					<h2 class="mt-3 text-lead">Thinking, in the open.</h2>
				</div>
				<a class="provenance link-accent" href="https://www.zldagroup.com/insights">
					all essays &#8599;
				</a>
			</div>
			<ul>
				{
					essays.map((e) => (
						<li>
							<a
								href={e.href}
								class="index-row group grid gap-1 border-b border-line/10 py-5 sm:grid-cols-[9rem_minmax(0,1fr)] sm:items-baseline sm:gap-8 lg:py-6"
							>
								<time datetime={e.date} class="provenance pt-0.5">{e.date}</time>
								<span class="text-body-l text-ink transition-colors duration-200 group-hover:text-accent-dark">
									{e.title}
								</span>
							</a>
						</li>
					))
				}
			</ul>
		</section>

		<!-- Closing: Now and Contact merged -->
		<section id="contact" class="scroll-mt-20 bg-bg-soft">
			<div class="wrap grid gap-10 py-14 sm:py-16 lg:grid-cols-[1.4fr_1fr] lg:gap-14">
				<div>
					<p class="kicker">Now</p>
					<h2 class="mt-4 text-lead">What I am working on.</h2>
					<div class="mt-6 space-y-4 text-body text-ink-soft">
						<p>
							Building <strong class="font-semibold text-ink">iepOS</strong> toward its first school
							pilots, which means the work has shifted from adding features to earning trust:
							compliance workflows, tenant boundaries, and the operational documentation that makes a
							district say yes.
						</p>
						<p>
							This August I join <strong class="font-semibold text-ink">Florida SouthWestern State
							College</strong> as an adjunct professor of business and technology. I hold an MBA in
							Information Systems and the PMP, with a Lean Six Sigma Black Belt and CSCP, and I am
							completing an MS in Data Analytics and AI at FGCU.
						</p>
						<p>
							Most of my remaining attention goes to one question: how do you put a language model
							somewhere consequential and still be able to prove what it did.
						</p>
					</div>
				</div>
				<aside class="lg:border-l lg:border-line/12 lg:pl-10">
					<p class="text-body-l text-ink">
						Open to conversations about AI governance, operations tooling, and anything involving a
						schema that has gotten away from someone.
					</p>
					<ul class="mt-6 space-y-2.5 text-body">
						<li><a class="link-accent" href="mailto:tanis226@gmail.com">tanis226@gmail.com</a></li>
						<li><a class="link-accent" href="https://www.linkedin.com/in/dtanis/">linkedin.com/in/dtanis</a></li>
						<li><a class="link-accent" href="https://github.com/tanis226-hue">github.com/tanis226-hue</a></li>
						<li><a class="link-accent" href="/David-Tanis-Resume.pdf">Résumé (PDF)</a></li>
						<li><a class="link-accent" href="/David-Tanis-CV.pdf">Academic CV (PDF)</a></li>
						<li><a class="link-accent" href="https://zldagroup.com/insights">ZLDA Insights</a></li>
						<li><a class="link-accent" href="https://zldagroup.com">zldagroup.com</a></li>
					</ul>
					<p class="mt-6 text-meta text-ink-muted">
						If it is about a business problem rather than me personally, ZLDA is the better front door.
					</p>
				</aside>
			</div>
		</section>
	</main>

	<footer class="wrap py-8">
		<div class="flex flex-wrap items-center justify-between gap-3 border-t border-line/12 pt-6 text-meta text-ink-muted">
			<p>David Tanis &middot; Naples, Florida</p>
			<p>Built with Astro</p>
		</div>
	</footer>
</Layout>
